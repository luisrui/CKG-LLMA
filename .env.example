# Copy this file to `.env` and fill in your own credentials.
# These variables are read by the LLM-augmentation scripts
# (gen_enhanced_graphs.py, gen_item_attributes.py, Explanation_generation.py).
#
# IMPORTANT: never commit real keys. `.env` is git-ignored.

# API key for the chat-completion endpoint used to augment / prune the KG.
LLM_API_KEY=your_api_key_here

# Chat-completion endpoint. Defaults to the HKUST-GZ gateway if unset.
LLM_API_BASE=https://gpt-api.hkust-gz.edu.cn/v1/chat/completions

# OpenAI key used by the explanation-generation module (modules/explanation).
OPENAI_API_KEY=your_openai_api_key_here
